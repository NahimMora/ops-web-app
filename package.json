{
  "name": "holasalta-ops-web-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "server.js",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev:server": "tsx watch apps/server/src/main.ts",
    "dev:web": "vite --config vite.config.ts",
    "dev:agent": "tsx watch apps/agent/src/main.ts",
    "bundle:server": "esbuild apps/server/src/main.ts --bundle --platform=node --format=esm --target=node22 --packages=external --sourcemap --outfile=dist/server/main.js",
    "bundle:agent": "esbuild apps/agent/src/main.ts --bundle --platform=node --format=esm --target=node22 --packages=external --sourcemap --outfile=dist/agent/main.js",
    "bundle:web": "vite build --config vite.config.ts",
    "build:server": "npm run bundle:server && npm run bundle:agent && npm run bundle:web && npm run check:hostinger",
    "build:agent": "npm run bundle:agent",
    "build:web": "npm run bundle:web",
    "build": "npm run build:server",
    "check:hostinger": "node scripts/check-hostinger-entrypoint.mjs",
    "start": "node server.js",
    "start:agent": "node dist/agent/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "secrets:generate": "node scripts/generate-secrets.mjs",
    "secrets:rotate-admin": "node scripts/rotate-admin-credentials.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.848.0",
    "@aws-sdk/lib-storage": "^3.848.0",
    "@aws-sdk/s3-request-presigner": "^3.848.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^10.1.0",
    "@vitejs/plugin-react": "^4.7.0",
    "dotenv": "^17.2.1",
    "esbuild": "^0.28.1",
    "fastify": "^5.4.0",
    "mysql2": "^3.14.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^7.0.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^24.0.15",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.31.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vitest": "^3.2.4"
  }
}
